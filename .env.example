# Anthropic API (Claude Haiku 4.5)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MessageBird SMS
MESSAGEBIRD_API_KEY=your_messagebird_api_key_here
MESSAGEBIRD_ORIGINATOR=SurfAlert

# Telefoonnummer voor alerts (NL formaat met +31)
RECIPIENT_PHONE_NUMBER=+31612345678

# Rollout configuratie
ALERTS_ENABLED=false
COOLDOWN_HOURS=4
MAX_ALERTS_PER_WEEK=8

# Debug
DEBUG=false