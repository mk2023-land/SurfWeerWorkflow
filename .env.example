# Anthropic API (Claude Haiku) — voor SMS/mail-tekst generatie
ANTHROPIC_API_KEY=sk-ant-...

# Notifier-keuze: 'ntfy' (gratis push, default), 'email' (gratis mail), 'twilio' (betaalde SMS)
NOTIFIER=ntfy

# --- ntfy.sh push (NOTIFIER=ntfy) ---
# Kies een onraadbare topic-naam (wie 'm kent kan jouw meldingen lezen).
# Installeer de ntfy-app op je telefoon en subscribe op deze topic.
NTFY_TOPIC=nwijksurf-mk-xxxxxxxxxxxx
# Optioneel ander relay-server-adres:
# NTFY_SERVER=https://ntfy.sh

# --- E-mail (NOTIFIER=email) ---
# Voor Gmail: zet 2FA aan en maak een App Password via
#   https://myaccount.google.com/apppasswords  (16-tekens)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw.botaccount@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_FROM_NAME=Noordwijk Surf Alert
# Ontvanger (default: SMTP_USER zelf)
RECIPIENT_EMAIL=jij@gmail.com

# --- Twilio SMS (NOTIFIER=twilio) — optioneel, voor fallback ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15555555555
RECIPIENT_PHONE_NUMBER=+31612345678

# Rollout configuratie
ALERTS_ENABLED=true
COOLDOWN_HOURS=4
MAX_ALERTS_PER_WEEK=8

# Debug = alleen log-niveau (heeft geen invloed op verzending).
DEBUG=false
