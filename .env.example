# Anthropic API (Claude Haiku) — voor SMS tekst generatie
ANTHROPIC_API_KEY=sk-ant-...

# Twilio SMS — Account SID, Auth Token en afzendernummer uit Twilio console
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15555555555

# Telefoonnummer voor alerts (NL formaat met +31)
RECIPIENT_PHONE_NUMBER=+31612345678

# Rollout configuratie
ALERTS_ENABLED=false
COOLDOWN_HOURS=4
MAX_ALERTS_PER_WEEK=8

# Debug: zet op true voor verbose logging (heeft geen invloed op SMS-verzending,
# gebruik daarvoor `python src/main.py --dry-run`).
DEBUG=false
